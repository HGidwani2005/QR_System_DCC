# Backend Environment Variables
# Copy this file to .env and fill in your Firebase credentials

# Firebase Service Account (download from Firebase Console > Project Settings > Service Accounts)
FIREBASE_SERVICE_ACCOUNT_PATH=./serviceAccountKey.json

# Firebase Project ID
FIREBASE_PROJECT_ID=your-firebase-project-id

# Server config
PORT=3001
ALLOWED_ORIGIN=http://localhost:5173

# Bennett University email domain
ALLOWED_EMAIL_DOMAIN=bennett.edu.in

# QR code expiry in minutes
QR_EXPIRY_MINUTES=10
